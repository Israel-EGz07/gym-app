{
  "version": 2,
  "builds": [
    {
      "src": "/frontend",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "frontend/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/build/index.html"
    }
  ]
}
